{
	"bsonType": "object",
	"required": ["canvas_data", "metadata"],
	"permission": {
		"read": "doc.is_public==true || (doc.is_public==false && doc.creator_uid==auth.uid && auth.uid != null)",
		"create": "auth.uid != null",
		"update": "doc.creator_uid==auth.uid",
		"delete": "doc.creator_uid==auth.uid"
	},
	"properties": {
		"_id": {
			"description": "发现作品ID，系统自动生成"
		},
		"share_code_id": {
			"bsonType": "string",
			"description": "关联的分享码ID（可选，发布时勾选同步生成）",
			"title": "分享码ID",
			"maxLength": 64
		},
		"creator_uid": {
			"bsonType": "string",
			"description": "创建者用户ID（关联uni-id-users）",
			"title": "创建者用户ID",
			"maxLength": 64,
			"foreignKey": "uni-id-users._id"
		},
		"canvas_data": {
			"bsonType": "object",
			"description": "画布数据（核心数据）",
			"title": "画布数据",
			"properties": {
				"width": {
					"bsonType": "int",
					"description": "画布宽度",
					"title": "画布宽度"
				},
				"height": {
					"bsonType": "int",
					"description": "画布高度",
					"title": "画布高度"
				},
				"beads": {
					"bsonType": "array",
					"description": "非透明像素点数组 [{x: 0, y: 0, color: '#FFFFFF'}, ...]",
					"arrayType": "object",
					"title": "像素点数组"
				},
				"palette": {
					"bsonType": "array",
					"description": "使用的颜色hex列表",
					"arrayType": "string",
					"title": "颜色列表"
				}
			}
		},
		"metadata": {
			"bsonType": "object",
			"description": "作品元数据",
			"title": "作品信息",
			"properties": {
				"title": {
					"bsonType": "string",
					"description": "作品标题",
					"title": "作品标题",
					"maxLength": 100
				},
				"description": {
					"bsonType": "string",
					"description": "作品描述",
					"title": "作品描述",
					"maxLength": 500
				},
				"tags": {
					"bsonType": "array",
					"description": "标签列表",
					"title": "标签列表",
					"arrayType": "string"
				}
			}
		},
		"settings": {
			"bsonType": "object",
			"description": "转换设置",
			"title": "转换设置",
			"properties": {
				"brand": {
					"bsonType": "string",
					"description": "拼豆品牌",
					"title": "拼豆品牌",
					"enum": [{
						"text": "Mard",
						"value": "mard"
					}, {
						"text": "Coco",
						"value": "coco"
					}, {
						"text": "咪小窝",
						"value": "miwo"
					}, {
						"text": "漫漫",
						"value": "manman"
					}, {
						"text": "盼盼",
						"value": "panpan"
					}],
					"defaultValue": "mard"
				},
				"colorMergeThreshold": {
					"bsonType": "int",
					"description": "颜色合并阈值",
					"title": "颜色合并阈值",
					"defaultValue": 30,
					"minimum": 0,
					"maximum": 100
				},
				"conversionMode": {
					"bsonType": "string",
					"description": "转换模式",
					"title": "转换模式",
					"enum": [{
						"text": "卡通",
						"value": "dominant"
					}, {
						"text": "图像",
						"value": "average"
					}],
					"defaultValue": "dominant"
				}
			}
		},
		"preview_image": {
			"bsonType": "string",
			"description": "预览图地址",
			"title": "预览图地址",
			"trim": "both"
		},
		"stats": {
			"bsonType": "object",
			"description": "统计数据",
			"title": "统计数据",
			"properties": {
				"view_count": {
					"bsonType": "int",
					"description": "浏览次数",
					"title": "浏览次数",
					"minimum": 0
				},
				"import_count": {
					"bsonType": "int",
					"description": "导入次数",
					"title": "导入次数",
					"minimum": 0
				}
			}
		},
		"is_public": {
			"bsonType": "bool",
			"description": "是否公开",
			"title": "是否公开",
			"defaultValue": true
		},
		"status": {
			"bsonType": "int",
			"description": "状态：1-正常，0-已删除，-1-已被举报",
			"title": "状态",
			"enum": [{
				"text": "正常",
				"value": 1
			}, {
				"text": "已删除",
				"value": 0
			}, {
				"text": "已被举报",
				"value": -1
			}],
			"defaultValue": 1
		},
		"create_date": {
			"bsonType": "timestamp",
			"description": "创建时间戳",
			"title": "创建时间戳",
			"forceDefaultValue": {
				"$env": "now"
			}
		},
		"update_date": {
			"bsonType": "timestamp",
			"description": "更新时间戳",
			"title": "更新时间戳",
			"forceDefaultValue": {
				"$env": "now"
			}
		}
	}
}
